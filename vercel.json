{
  "version": 2,
  "builds": [
    {
      "src": "vercel-entry.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/vercel-entry.js" },
    { "src": "/login", "dest": "/client/login.html" },
    { "src": "/signup", "dest": "/client/signup.html" },
    { "src": "/dashboard", "dest": "/client/dashboard.html" },
    { "src": "/experiments", "dest": "/client/experiments.html" },
    { "src": "/add-experiment", "dest": "/client/add-experiment.html" },
    { "src": "/edit-experiment", "dest": "/client/edit-experiment.html" },
    { "src": "/experiment-details", "dest": "/client/experiment-details.html" },
    { "src": "/compare", "dest": "/client/compare.html" },
    { "src": "/profile", "dest": "/client/profile.html" },
    { "src": "/about-us", "dest": "/client/about-us.html" },
    { "src": "/manual", "dest": "/client/manual.html" },
    { "src": "/", "dest": "/client/index.html" },
    { "src": "/(.*)", "dest": "/client/$1" }
  ]
}
