{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/vercel-entry.js" },
    { "source": "/login", "destination": "/client/login.html" },
    { "source": "/signup", "destination": "/client/signup.html" },
    { "source": "/dashboard", "destination": "/client/dashboard.html" },
    { "source": "/experiments", "destination": "/client/experiments.html" },
    { "source": "/add-experiment", "destination": "/client/add-experiment.html" },
    { "source": "/edit-experiment", "destination": "/client/edit-experiment.html" },
    { "source": "/experiment-details", "destination": "/client/experiment-details.html" },
    { "source": "/compare", "destination": "/client/compare.html" },
    { "source": "/profile", "destination": "/client/profile.html" },
    { "source": "/about-us", "destination": "/client/about-us.html" },
    { "source": "/manual", "destination": "/client/manual.html" },
    { "source": "/", "destination": "/client/index.html" },
    { "source": "/(.*)", "destination": "/client/$1" }
  ]
}
